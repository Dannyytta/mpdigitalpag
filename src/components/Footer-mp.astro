---
const footerLinks = [
  { href: '#hero', label: 'Inicio' },
  { href: '#proveedores', label: 'Proveedores' },
  { href: '#vendemos', label: 'Qué vendemos' },
  { href: '#historia', label: 'Historia' },
];
---

<footer class="site-footer" aria-labelledby="footer-title">
  <div class="container footer-shell">
    <div class="footer-intro">
      <h4 class="footer-eyebrow"> MP Digital</h4>

    </div>

    <div class="footer-content">
      <section class="footer-card footer-brand-block" aria-label="Resumen de marca">
        <img class="marca" src="/favicon.svg" alt="">
        <p>
          Abastecimiento y gestión comercial para Mercado Público.
        </p>
        
      </section>

      <nav class="footer-card" aria-label="Navegación secundaria">
        <p class="footer-card-title">Navegación</p>
        <ul class="footer-links">
          {footerLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>

      <section class="footer-card footer-highlight" aria-label="Mensaje de cierre">
        <p class="footer-card-title">Contacto</p>
        
          <li>dbo@mpdigital.cl</li>
          <li> spl@mpdigital.cl </li>
          <li>+56 9 5520 5924</li>
          
          
        
        
      </section>

      <section class="footer-card footer-highlight" aria-label="Mensaje de cierre">
        <p class="footer-card-title">Información</p>
        <li>Operación estructurada para Mercado Público</li>
        <li>Documentación disponible según requerimiento</li>
        <li> <a href="/MPDigital_Ficha_Empresa.pdf" target="_blank">Descargar ficha empresa</a> </li>

        
      </section>
    </div>

    <div class="footer-bottom">
      <p>© 2026 MP Digital. Todos los derechos reservados.</p>
      <p>Parte de <a href="https://digitalworks.cl/" target="_blank">DigitalWorks.</a><small>Diseño y desarrollo interno</small></p>
      
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:
      radial-gradient(circle at top, rgba(201, 137, 75, 0.12), transparent 30%),
      linear-gradient(180deg, #0f1720 0%, #111b26 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-shell {
    width: auto;
    height: 300px;
    padding: 2rem;
  }

  .footer-intro {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .footer-eyebrow,
  .footer-card-title,
  .footer-badge,
  .footer-bottom p:last-child {
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .footer-eyebrow,
  .footer-card-title,
  .footer-badge,
  .footer-cta,
  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: #c9894b;
  }

  .footer-intro h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .footer-description,
  .footer-card p,
  .footer-links a,
  .footer-bottom p {
    color: #c7d1db;
    line-height: 1.75;
    font-size: 1rem;
  }

  .footer-description {
    margin: 1rem 0 0;
    max-width: 58ch;
  }

  .footer-content {
    display: grid;
    grid-template-columns:  repeat(4, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .footer-brand,
  .footer-card {
    width: 15rem;
    min-height: 50%;
    padding: 1.75rem;
    border-radius: 15px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 50px rgba(3, 8, 12, 0.24);
  }

  .marca {
    width: 25%;
  }


  .footer-brand-block p,
  .footer-highlight p {
    margin: 0;
  }

  .footer-highlight li {
    cursor: pointer;
  }

  a {
    text-decoration: none;
    color: #c7d1db;
  }

  a:hover {
    color: #c9894b;
  } 

  .footer-badge {
    display: inline-flex;
    margin-top: 1.5rem;
  }

  .footer-card-title {
    margin: 0 0 1rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .footer-links a {
    transition: color 180ms ease, transform 180ms ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    transform: translateX(2px);
  }

  .footer-highlight {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bottom p {
    margin: 0;
  }

  
 

  @media (max-width: 900px) {
    .footer-content {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-shell {
      padding-top: 4rem;
    }

    .footer-card {
      padding: 1.5rem;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
