

---
import '../styles/global.css';
import NavbarMp from "../components/Navbar-mp.astro";
import FooterMp from "../components/Footer-mp.astro";


const supplierPoints = [
  {
    title: 'Disponibilidad real',
    description:
      'Evaluamos proveedores según stock, tiempos y condiciones en cada proceso.',
  },
  {
    title: 'Criterio sobre catálogo',
    description:
      'Priorizamos la opción más adecuada para cumplir con el requerimiento, no una base predefinida',
  },
  {
    title: 'Continuidad operativa',
    description:
      'Mantenemos relaciones activas que permiten dar estabilidad y respuesta sostenida.',
  },
  {
    title: 'Flexibilidad comercial',
    description:
      'Nos adaptamos a las condiciones de cada proceso para responder de forma oportuna.',
  },

];

const productCards = [
  {
    title: 'Hardware',
    description:
      'Componentes y equipamiento asociado a infraestructura tecnológica.',
  },
  {
    title: 'Tecnología',
    description:
      'Equipos, periféricos y soluciones necesarias para la operación digital.',
  },
  {
    title: 'Insumos de oficina',
    description:
      'Papelería, tóners y productos de uso diario institucional.',
  },
    {
    title: 'Requerimientos especiales',
    description:
      'Cuando una compra incluye productos fuera de estas líneas, gestionamos su abastecimiento a través de proveedores asociados.',
  },
];

const storyBullets = [
  'Sostenemos la operación con estructura',
  'Diseñamos procesos reales para compra y seguimiento',
  'Separamos gestión comercial de ejecución operativa',
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="MP Digital conecta abastecimiento confiable, criterio comercial y una operación preparada para crecer."
    />
    <title>MP Digital | Abastecimiento corporativo confiable</title>
  </head>
  <body>
    <header class="site-header">
      <NavbarMp/>
    </header>

    <main>
      <section class="hero" id="hero">
        <div class="hero-media-wrap" aria-hidden="true">
          <img
            class="hero-media"
            src="/hero-corporate.png"
            alt=""
            loading="eager"
            decoding="async"
          />
          <div class="hero-overlay"></div>
        </div>

        <div class="hero-content container">
          <p class="eyebrow hero-copy">Eficiencia comercial en Mercado Público</p>
          <h1 class="hero-title hero-copy">
            Gestionamos ventas al Estado con foco en cumplimiento y resultados.
          </h1>
          <p class="hero-description hero-copy">
            Agilizamos el proceso comercial para responder mejor y concretar más oportunidades.
          </p>
          <div class="hero-actions hero-copy">
            <a class="button-primary" href="#vendemos">Ver soluciones</a>
            <a class="button-secondary" href="#historia">Nuestra historia</a>
          </div>
        </div>
      </section>

      <section class="section section-dark" id="proveedores">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow copper">Selección y gestión de proveedores</p>
            <h2>Cómo operamos con proveedores</h2>
            <p>
              No trabajamos con un catálogo fijo. Seleccionamos proveedores según disponibilidad real, tiempos de respuesta y capacidad de cumplimiento.
            </p>
          </div>

          <div class="supplier-panel">
            {supplierPoints.map((point) => (
              <article class="supplier-item">
                <span class="supplier-icon" aria-hidden="true">✦</span>
                <h3>{point.title}</h3>
                <p>{point.description}</p>
              </article>
            ))}
          </div>

          <div class="supplier-panel proveedores">
            <h3 class="top-prov">Relación con proveedores</h3>
            <p>Buscamos construir relaciones de trabajo estables con proveedores que quieran crecer en el mercado público. <br>
            Operamos absorbiendo los tiempos de pago del sistema, permitiendo pagos más inmediatos y continuidad operativa.</p>
          </div>
        </div>
      </section>

      <section class="section section-light" id="vendemos">
        <div class="container">
          <div class="section-heading narrow">
            <p class="eyebrow muted">Qué abastecemos</p>
            <h2>Tecnología y abastecimiento operativo para el Estado</h2>
            <p>
              Nos enfocamos en tecnología, hardware e insumos de oficina. <br>Cuando el proceso lo requiere, gestionamos requerimientos complementarios sin afectar el cumplimiento.
            </p>
            <h3>Priorizamos el cumplimiento del proceso por sobre la rigidez del catálogo.</h3>
          </div>

          <div class="product-grid">
            {productCards.map((card) => (
              <article class="product-card">
                <div class="product-accent"></div>
                <h3>{card.title}</h3>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-story" id="historia">
        <div class="container story-grid">
          <div class="section-heading story-copy">
            <p class="eyebrow copper">Nuestra historia</p>
            <h2>Gestión estructurada para la operación en Mercado Público</h2>
                          <p>
                          MP Digital nace desde la experiencia directa en procesos de venta y abastecimiento en Mercado Público.

              Con el tiempo entendimos cómo se sostiene realmente una operación: cómo se toman decisiones, cómo se gestionan los tiempos y qué permite dar continuidad sin depender de la improvisación.

              Ese aprendizaje nos llevó a estructurar una forma de trabajo clara, enfocada en cumplir y sostener resultados en el tiempo.  

              <br><br>Hoy operamos con una base técnica y una mirada práctica del mercado, entendiendo tanto al comprador como al proceso completo.
            </p>
            <p class="story-note">
              Parte de <span> <a href="https://digitalworks.cl/" target="_blank">DigitalWorks</a> </span>, donde desarrollamos soluciones tecnológicas y procesos para empresas en crecimiento.
            </p>
          </div>

          <div class="story-panel">
            <ul>
              {storyBullets.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <FooterMp />
    </main>

    <script>
      import { gsap } from 'gsap';

      const runHeroAnimation = () => {
        const heroImage = document.querySelector('.hero-media');
        const heroCopies = document.querySelectorAll('.hero-copy');

        if (!heroImage || !heroCopies.length) return;

        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
        tl.fromTo(
          heroImage, 
          
          { scale: 1,
            opacity: -1,
           }, 
          
          { scale: 1.08, 
            opacity: 1,
            duration: 2.8 }
        );

        tl.fromTo(
          heroCopies,
          { y: 0, opacity: 0 },
          { y: 0, opacity: 1, duration: 1, stagger: 0.12 },
          '-=1.1'
        );
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runHeroAnimation, { once: true });
      } else {
        runHeroAnimation();
      }
    </script>

    
  </body>
</html>

