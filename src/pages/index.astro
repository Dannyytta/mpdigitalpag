---
const supplierPoints = [
  {
    title: 'Red de proveedores validada',
    description:
      'Trabajamos con aliados que responden con tiempos, documentación y continuidad operativa.',
  },
  {
    title: 'Criterio antes que catálogo',
    description:
      'Seleccionamos soluciones según contexto, presupuesto y exigencia real del proyecto.',
  },
  {
    title: 'Seguimiento de punta a punta',
    description:
      'Acompañamos el proceso con comunicación clara para que cada compra tenga trazabilidad.',
  },
];

const productCards = [
  {
    title: 'Abastecimiento técnico',
    description:
      'Equipos, insumos y soluciones para operación diaria con foco en confiabilidad y tiempos de respuesta.',
  },
  {
    title: 'Compras estratégicas',
    description:
      'Búsqueda y comparación de alternativas para licitaciones, contratos y requerimientos de mayor escala.',
  },
  {
    title: 'Soporte comercial',
    description:
      'Presentamos propuestas claras, ordenadas y listas para acelerar validaciones internas.',
  },
];

const storyBullets = [
  'Aprendimos a sostener operación sin improvisar.',
  'Diseñamos procesos reales para compras y seguimiento.',
  'Creamos una separación clara y saludable con DigitalWorks.',
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="MP Digital conecta abastecimiento confiable, criterio comercial y una operación preparada para crecer."
    />
    <title>MP Digital | Abastecimiento corporativo confiable</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar container" aria-label="Principal">
        <a class="brand" href="#hero">MP Digital</a>
        <div class="nav-links">
          <a href="#proveedores">Proveedores</a>
          <a href="#vendemos">Qué vendemos</a>
          <a href="#historia">Historia</a>
        </div>
        <a class="nav-cta" href="#vendemos">Conversemos</a>
      </nav>
    </header>

    <main>
      <section class="hero" id="hero">
        <div class="hero-media-wrap" aria-hidden="true">
          <img
            class="hero-media"
            src="/hero-corporate.svg"
            alt=""
            loading="eager"
            decoding="async"
          />
          <div class="hero-overlay"></div>
        </div>

        <div class="hero-content container">
          <p class="eyebrow hero-copy">Operación comercial con criterio</p>
          <h1 class="hero-title hero-copy">
            Soluciones corporativas que transmiten orden, confianza y ejecución.
          </h1>
          <p class="hero-description hero-copy">
            Construimos relaciones comerciales sólidas, seleccionamos proveedores confiables y
            presentamos propuestas claras para que cada decisión avance con respaldo.
          </p>
          <div class="hero-actions hero-copy">
            <a class="button-primary" href="#vendemos">Ver soluciones</a>
            <a class="button-secondary" href="#historia">Nuestra historia</a>
          </div>
        </div>
      </section>

      <section class="section section-dark" id="proveedores">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow copper">Proveedores confiables</p>
            <h2>Elegimos respaldo operativo antes que ruido comercial.</h2>
            <p>
              Nuestro enfoque combina análisis, red de aliados y seguimiento real para que cada
              propuesta se vea seria desde el primer contacto.
            </p>
          </div>

          <div class="supplier-panel">
            {supplierPoints.map((point) => (
              <article class="supplier-item">
                <span class="supplier-icon" aria-hidden="true">✦</span>
                <h3>{point.title}</h3>
                <p>{point.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-light" id="vendemos">
        <div class="container">
          <div class="section-heading narrow">
            <p class="eyebrow muted">Qué vendemos</p>
            <h2>Oferta comercial clara, flexible y lista para entornos exigentes.</h2>
            <p>
              Organizamos cada solución para que sea fácil de entender, comparar y validar. Menos
              discurso, más criterio aplicado a resultados concretos.
            </p>
          </div>

          <div class="product-grid">
            {productCards.map((card) => (
              <article class="product-card">
                <div class="product-accent"></div>
                <h3>{card.title}</h3>
                <p>{card.description}</p>
                <span>Enfoque consultivo</span>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section section-story" id="historia">
        <div class="container story-grid">
          <div class="section-heading story-copy">
            <p class="eyebrow copper">Nuestra historia</p>
            <h2>Empezamos resolviendo necesidades reales. Seguimos creciendo con la misma disciplina.</h2>
            <p>
              MP Digital nació desde la operación, entendiendo cómo se sostiene el trabajo diario y
              qué necesita una empresa para comprar mejor, avanzar con seguridad y cuidar su ritmo.
            </p>
            <p class="story-note">
              Parte de <span>DigitalWorks</span>, con una identidad comercial enfocada en orden,
              servicio y ejecución responsable.
            </p>
          </div>

          <div class="story-panel">
            <ul>
              {storyBullets.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    </main>

    <script>
      import { gsap } from 'gsap';

      const runHeroAnimation = () => {
        const heroImage = document.querySelector('.hero-media');
        const heroCopies = document.querySelectorAll('.hero-copy');

        if (!heroImage || !heroCopies.length) return;

        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
        tl.fromTo(heroImage, { scale: 1.12 }, { scale: 1, duration: 1.8 });
        tl.fromTo(
          heroCopies,
          { y: 32, opacity: 0 },
          { y: 0, opacity: 1, duration: 1, stagger: 0.12 },
          '-=1.1'
        );
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', runHeroAnimation, { once: true });
      } else {
        runHeroAnimation();
      }
    </script>
  </body>
</html>

<style>
  :root {
    --bg-dark: #0f1720;
    --bg-dark-soft: #1b2633;
    --bg-light: #eef2f5;
    --text-primary: #f5f7fa;
    --text-secondary: #c7d1db;
    --text-muted: #8a98a8;
    --brand-blue: #2f5d7c;
    --brand-blue-hover: #3f7fa6;
    --brand-copper: #c9894b;
    --container: min(1120px, calc(100% - 2rem));
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg-dark);
    color: var(--text-primary);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .container {
    width: var(--container);
    margin: 0 auto;
  }

  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 20;
    padding-top: 1.25rem;
  }

  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1.2rem;
    background: rgba(15, 23, 32, 0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 999px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
  }

  .brand {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    color: rgba(245, 247, 250, 0.82);
    font-size: 0.96rem;
  }

  .nav-links a:hover,
  .nav-links a:focus-visible,
  .button-secondary:hover,
  .button-secondary:focus-visible {
    color: #fff;
  }

  .nav-cta,
  .button-primary,
  .button-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    transition: 180ms ease;
  }

  .nav-cta,
  .button-primary {
    background: var(--brand-blue);
    color: var(--text-primary);
    padding: 0.85rem 1.35rem;
    font-weight: 600;
  }

  .nav-cta:hover,
  .nav-cta:focus-visible,
  .button-primary:hover,
  .button-primary:focus-visible {
    background: var(--brand-blue-hover);
    transform: translateY(-1px);
  }

  .button-secondary {
    border: 1px solid rgba(245, 247, 250, 0.18);
    padding: 0.85rem 1.35rem;
    color: rgba(245, 247, 250, 0.86);
  }

  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    align-items: end;
    overflow: clip;
    isolation: isolate;
    background: var(--bg-dark);
  }

  .hero-media-wrap,
  .hero-overlay {
    position: absolute;
    inset: 0;
  }

  .hero-media-wrap {
    overflow: hidden;
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform-origin: center center;
    will-change: transform;
  }

  .hero-overlay {
    background: linear-gradient(to bottom, rgba(15, 23, 32, 0.2), rgba(15, 23, 32, 0.85));
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 10rem 0 7rem;
    max-width: 760px;
  }

  .hero-copy {
    opacity: 0;
  }

  .eyebrow {
    margin: 0 0 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .hero-title,
  .section-heading h2 {
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 5.6rem);
    max-width: 12ch;
  }

  .hero-description,
  .section-heading p,
  .supplier-item p,
  .product-card p,
  .story-panel li {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .hero-description {
    max-width: 60ch;
    margin: 1.5rem 0 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .section {
    padding: clamp(5rem, 9vw, 7.5rem) 0;
  }

  .section-dark {
    background: var(--bg-dark-soft);
  }

  .section-light {
    background: var(--bg-light);
    color: #16202b;
  }

  .section-light .section-heading p,
  .section-light .product-card p,
  .section-light .product-card span,
  .section-light .eyebrow {
    color: #506071;
  }

  .section-story {
    background: var(--bg-dark);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }

  .section-heading.narrow {
    max-width: 720px;
  }

  .section-heading h2 {
    font-size: clamp(2rem, 4vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .copper,
  .supplier-icon,
  .story-panel li::marker {
    color: var(--brand-copper);
  }

  .muted {
    color: #5d7284;
  }

  .supplier-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    padding: 1.25rem;
    border-radius: 24px;
    background: linear-gradient(145deg, rgba(27, 38, 51, 0.9), rgba(15, 23, 32, 0.95));
    border: 1px solid rgba(201, 137, 75, 0.12);
    box-shadow: 0 20px 60px rgba(4, 10, 15, 0.3);
  }

  .supplier-item {
    padding: 1.75rem;
    border-right: 1px solid rgba(201, 137, 75, 0.25);
  }

  .supplier-item:last-child {
    border-right: 0;
  }

  .supplier-icon {
    display: inline-flex;
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
  }

  .supplier-item h3,
  .product-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1.32rem;
    line-height: 1.2;
  }

  .supplier-item p,
  .product-card p {
    margin: 0;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .product-card {
    position: relative;
    overflow: hidden;
    background: #fff;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-bottom: 2px solid transparent;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .product-card:hover,
  .product-card:focus-within {
    transform: translateY(-4px);
    border-color: var(--brand-copper);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.08);
  }

  .product-accent {
    width: 2.75rem;
    height: 0.24rem;
    border-radius: 999px;
    background: rgba(201, 137, 75, 0.85);
    margin-bottom: 1.5rem;
  }

  .product-card span {
    display: inline-flex;
    margin-top: 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .story-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 2rem;
    align-items: start;
  }

  .story-note {
    margin-top: 1.5rem;
    color: var(--text-muted);
  }

  .story-note span {
    color: #6fa9c9;
    font-weight: 600;
  }

  .story-panel {
    padding: 2rem;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .story-panel ul {
    margin: 0;
    padding-left: 1.3rem;
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 960px) {
    .navbar {
      border-radius: 24px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-links {
      order: 3;
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .supplier-panel,
    .product-grid,
    .story-grid {
      grid-template-columns: 1fr;
    }

    .supplier-item {
      border-right: 0;
      border-bottom: 1px solid rgba(201, 137, 75, 0.25);
    }

    .supplier-item:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding-top: 0.75rem;
    }

    .navbar {
      padding: 1rem;
    }

    .nav-cta {
      width: 100%;
    }

    .hero-content {
      padding: 9rem 0 5rem;
    }

    .hero-title {
      max-width: 10ch;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .button-primary,
    .button-secondary {
      width: 100%;
    }

    .section {
      padding: 5rem 0;
    }

    .supplier-item,
    .product-card,
    .story-panel {
      padding: 1.5rem;
    }
  }
</style>
